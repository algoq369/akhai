{
  "name": "akhai",
  "version": "1.0.0",
  "private": true,
  "description": "AkhAI - Sovereign AI Intelligence System with 20 Thinking Methodologies and Multi-AI Consensus",
  "keywords": [
    "ai",
    "sovereign",
    "consensus",
    "methodologies",
    "chain-of-thought",
    "tree-of-thoughts",
    "multi-agent"
  ],
  "author": "Sheikh Raza",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@8.15.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,md,json}\"",
    "type-check": "turbo run type-check",
    "test": "turbo run test",
    "clean": "turbo run clean && rm -rf node_modules",
    "clean:workspaces": "turbo run clean",
    "prepare": "husky"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.29.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.2.4",
    "turbo": "^1.12.0",
    "typescript": "^5.9.3"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "lint-staged": {
    "packages/web/**/*.{ts,tsx}": [
      "prettier --write"
    ]
  },
  "pnpm": {
    "overrides": {
      "minimatch@<3.1.3": ">=3.1.3",
      "minimatch@>=9.0.0 <9.0.6": ">=9.0.6",
      "handlebars@>=4.0.0 <=4.7.8": ">=4.7.9",
      "flatted@<3.3.3": ">=3.3.3",
      "defu@<6.1.5": ">=6.1.5",
      "axios@<1.15.1": ">=1.15.1",
      "protobufjs@<7.5.6": ">=7.5.6",
      "lodash@<=4.17.23": ">=4.18.0",
      "undici@>=7.0.0 <7.24.0": ">=7.24.0",
      "hono@<4.12.18": ">=4.12.18",
      "rollup@>=4.0.0 <4.59.0": ">=4.59.0",
      "picomatch@<2.3.2": ">=2.3.2",
      "picomatch@>=4.0.0 <4.0.4": ">=4.0.4",
      "path-to-regexp@>=8.0.0 <8.4.0": ">=8.4.0",
      "fast-uri@<=3.1.0": ">=3.1.1"
    }
  }
}
