# ============================================================
# AkhAI deploy configuration — copy to deploy/deploy.env (gitignored) and edit.
# A host migration (e.g. FlokiNET → Hetzner) is editing THIS ONE FILE.
# Every value below is today's working FlokiNET deploy — the documented default;
# with no deploy.env at all, the scripts behave exactly as before.
# Override precedence: defaults < deploy.env < environment < CLI flags.
# ============================================================

# Where to deploy
DEPLOY_HOST=82.221.101.3          # VPS IP or hostname
DEPLOY_USER=akhai                 # ssh + app user

# Layout on the host
APP_DIR=/home/akhai/app                            # legacy pnpm tree (rollback target)
STANDALONE_DIR=/home/akhai/app-standalone          # standalone runtime (the live app)
DATA_DIR=/home/akhai/app/packages/web/data         # sqlite files — survives every deploy
CACHE_DIR=/home/akhai/app/packages/web/.cache      # transformers model cache (~23MB) — survives
HOST_ENV_FILE=/home/akhai/app/packages/web/.env.local  # the host's real secrets (never synced)

# Runtime
APP_PORT=3000                     # production port (Caddy reverse-proxies to it)
VERIFY_PORT=3001                  # side-by-side boot-verify port
PM2_NAME=akhai                    # production PM2 app name
PM2_VERIFY_NAME=akhai-next        # staging/verify PM2 app name

# Domain + provisioning (setup-vps.sh / setup-domain.sh)
DOMAIN=                           # e.g. akhai.app
NODE_MAJOR=20                     # Node major line installed on a fresh VPS
PNPM_VERSION=8.15.0
MIN_FREE_MB=1024                  # preflight: minimum free disk on the VPS
