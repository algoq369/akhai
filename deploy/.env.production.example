# ============================================================
# AkhAI production environment — regenerated 2026-07-17 (B7) from actual
# process.env usage in packages/web (grep-derived, not hand-guessed).
# Copy to the VPS at $HOST_ENV_FILE (default: /home/akhai/app/packages/web/.env.local).
# PLACEHOLDERS ONLY — never commit a real value to this file.
# ============================================================

# ──────────────────────────── REQUIRED ────────────────────────────
# The app refuses to boot without these two (lib/env.ts).
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME              # primary reasoning (Claude)
OPENROUTER_API_KEY=sk-or-REPLACE_ME              # free-model lane + GTP advisors

NODE_ENV=production
NEXT_PUBLIC_APP_URL=https://your-domain.com      # canonical app URL (auth callbacks, links)
NEXT_PUBLIC_BASE_URL=https://your-domain.com     # public base URL used in a few legacy spots

# ──────────────────────────── MONITORING ──────────────────────────
SENTRY_DSN=https://REPLACE_ME.ingest.sentry.io/0             # server-side error reporting
NEXT_PUBLIC_SENTRY_DSN=https://REPLACE_ME.ingest.sentry.io/0 # client-side error reporting

# ──────────────────────────── SEARCH / GROUNDING ──────────────────
BRAVE_SEARCH_API_KEY=BSA-REPLACE_ME              # auto web-search grounding on every query
BRAVE_API_KEY=BSA-REPLACE_ME                     # legacy alias still read by one route
GUARD_NLI_URL=https://REPLACE_ME                 # NLI entailment service for the grounding guard
GUARD_NLI_TOKEN=REPLACE_ME                       # bearer token for GUARD_NLI_URL

# ──────────────────────────── GTP CONSENSUS ADVISORS ──────────────
# Optional: each missing key removes that advisor/fallback from the chain.
DEEPSEEK_API_KEY=sk-REPLACE_ME                   # DeepSeek advisor
MISTRAL_API_KEY=REPLACE_ME                       # Mistral advisor
XAI_API_KEY=xai-REPLACE_ME                       # xAI Grok advisor
GROQ_API_KEY=gsk_REPLACE_ME                      # Groq fallback provider
GOOGLE_API_KEY=AIza-REPLACE_ME                   # Google fallback provider

# ──────────────────────────── PAYMENTS: STRIPE ─────────────────────
STRIPE_SECRET_KEY=sk_live_REPLACE_ME             # server-side Stripe API
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME           # webhook signature verification
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_REPLACE_ME
NEXT_PUBLIC_STRIPE_PRO_PRICE_ID=price_REPLACE_ME        # Pro subscription
NEXT_PUBLIC_STRIPE_TEAM_PRICE_ID=price_REPLACE_ME       # Team subscription
NEXT_PUBLIC_STRIPE_LEGEND_PRICE_ID=price_REPLACE_ME     # Legend tier
NEXT_PUBLIC_STRIPE_INSTINCT_PRICE_ID=price_REPLACE_ME   # Instinct add-on
NEXT_PUBLIC_STRIPE_CREDITS_STARTER_ID=price_REPLACE_ME  # credit pack: starter
NEXT_PUBLIC_STRIPE_CREDITS_BUILDER_ID=price_REPLACE_ME  # credit pack: builder
NEXT_PUBLIC_STRIPE_CREDITS_SCALE_ID=price_REPLACE_ME    # credit pack: scale
NEXT_PUBLIC_STRIPE_CREDITS_BULK_ID=price_REPLACE_ME     # credit pack: bulk

# ──────────────────────────── PAYMENTS: CRYPTO ─────────────────────
NOWPAYMENTS_API_KEY=REPLACE_ME                   # NOWPayments API
NOWPAYMENTS_IPN_SECRET=REPLACE_ME                # NOWPayments IPN signature check
NOWPAYMENTS_SANDBOX=false                        # true only when testing
BTCPAY_SERVER_URL=https://REPLACE_ME             # BTCPay Server instance
BTCPAY_API_KEY=REPLACE_ME
BTCPAY_STORE_ID=REPLACE_ME
BTCPAY_WEBHOOK_SECRET=REPLACE_ME

# ──────────────────────────── AUTH / OAUTH (optional) ──────────────
GITHUB_CLIENT_ID=REPLACE_ME                      # GitHub social login
GITHUB_CLIENT_SECRET=REPLACE_ME
GITHUB_REDIRECT_URI=https://your-domain.com/api/auth/github/callback
TWITTER_CLIENT_ID=REPLACE_ME                     # X/Twitter social login
TWITTER_CLIENT_SECRET=REPLACE_ME
TWITTER_REDIRECT_URI=https://your-domain.com/api/auth/twitter/callback

# ──────────────────────────── EMAIL (optional) ─────────────────────
RESEND_API_KEY=re_REPLACE_ME                     # transactional email
RESEND_FROM_EMAIL=noreply@your-domain.com

# ──────────────────────────── ANALYTICS (optional) ─────────────────
NEXT_PUBLIC_POSTHOG_KEY=phc_REPLACE_ME
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
NEXT_PUBLIC_OPENPANEL_CLIENT_ID=REPLACE_ME

# ──────────────────────────── FEATURE SWITCHES ─────────────────────
EMBED_ROUTER=on                                  # semantic methodology router; 'off' = kill-switch
REACT_AGENT_LIVE=1                               # live ReAct agent with real tool use (signed-in)
F2_LIVE=0                                        # F2 A/B live lane (leave 0 unless testing)
SC_MULTIPATH=0                                   # SC multipath experiment (leave 0 in prod)
PROVIDER_TIMEOUT_MS=55000                        # per-provider API timeout override

# ──────────────────────────── MISC (optional) ──────────────────────
YOUTUBE_API_KEY=AIza-REPLACE_ME                  # YouTube metadata for URL visitor
COINMARKETCAP_API_KEY=REPLACE_ME                 # crypto price data
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=REPLACE_ME  # wallet connect (crypto payments UI)
TRANSFORMERS_CACHE=                              # override model-cache dir (blank = ./.cache, symlinked by deploy)
# OPENROUTER_BASE_URL=                           # DEV-ONLY test seam — must stay unset in prod
# SKIP_ENV_VALIDATION=                           # CI escape hatch — never set in prod
# Excluded by design (platform-injected, never set by hand):
#   NEXT_RUNTIME (set by Next.js itself) · NEXT_PUBLIC_VERCEL_URL (Vercel-only, N/A on a VPS)
