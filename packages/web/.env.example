# ============================================================
# AkhAI Environment Variables
# Copy to .env.local and fill in your values
# Required vars are marked — app fails to build without them
# ============================================================

# AI Providers (REQUIRED — at least one)
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here        # Required
OPENROUTER_API_KEY=sk-or-v1-your-key-here           # Required (free tier fallback)

# Search (optional — enables web grounding)
BRAVE_SEARCH_API_KEY=BSA-your-key-here

# Email Auth (optional — enables email sign-in)
RESEND_API_KEY=re_your-key-here

# Analytics — PostHog EU (optional)
NEXT_PUBLIC_POSTHOG_KEY=phc_your-key-here
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# Error Tracking — Sentry (optional)
NEXT_PUBLIC_SENTRY_DSN=https://your-dsn@sentry.io/project-id
SENTRY_DSN=https://your-dsn@sentry.io/project-id
SENTRY_ORG=your-org
SENTRY_PROJECT=akhai
SENTRY_AUTH_TOKEN=sntrys_your-token-here

# User Behavior Analytics — OpenPanel (optional)
NEXT_PUBLIC_OPENPANEL_CLIENT_ID=your-client-id-here

# App URL (for callbacks)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Stripe Payments (optional — enables subscriptions)
STRIPE_SECRET_KEY=sk_test_your-key-here
STRIPE_WEBHOOK_SECRET=whsec_your-secret-here
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-key-here
NEXT_PUBLIC_STRIPE_PRO_PRICE_ID=price_pro_id
NEXT_PUBLIC_STRIPE_LEGEND_PRICE_ID=price_legend_id

# Crypto Payments — NOWPayments (optional)
NOWPAYMENTS_API_KEY=your-key-here
NOWPAYMENTS_IPN_SECRET=your-secret-here

# Crypto Payments — BTCPay Server (optional)
BTCPAY_SERVER_URL=https://btcpay.your-domain.com
BTCPAY_API_KEY=your-key-here
BTCPAY_STORE_ID=your-store-id
BTCPAY_WEBHOOK_SECRET=your-secret-here

# GitHub OAuth (optional — GitHub auth suspended)
GITHUB_CLIENT_ID=your-client-id
GITHUB_CLIENT_SECRET=your-client-secret

# Twitter/X OAuth 2.0 (optional — social connector)
TWITTER_CLIENT_ID=your-client-id
TWITTER_CLIENT_SECRET=your-client-secret

# Wallet Auth — Reown (optional)
NEXT_PUBLIC_REOWN_PROJECT_ID=your-project-id
